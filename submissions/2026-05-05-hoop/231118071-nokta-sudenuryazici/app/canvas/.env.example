# Google Cloud Console'dan alınan OAuth2 Client ID
# Nasıl alınır: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Tür: Web Application
# Authorized JavaScript origins: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=BURAYA_CLIENT_ID_GELECEK

# Google Cloud Console'dan alınan OAuth2 Client Secret
VITE_GOOGLE_CLIENT_SECRET=BURAYA_CLIENT_SECRET_GELECEK

# Gemini API Key (AI destekli dashboard üretimi için)
# Nasıl alınır: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=BURAYA_GEMINI_API_KEY_GELECEK

# Gemini Model Configuration
# Available models (v1 API): gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash, gemini-2.5-flash-lite
# Fallback order will be tried automatically if primary model fails
# Recommended: gemini-2.5-flash (fast, 1M input tokens, 65K output, thinking mode)
VITE_GEMINI_MODEL=gemini-2.5-flash

# 3. Mevcut Gemini Modelleri (2025)
# 
#   | Model                 | Açıklama   | Input | Output | Özellikler      |
#   |-----------------------|------------|-------|--------|-----------------|
#   | gemini-2.5-flash      | ⭐ Önerilen | 1M    | 65K    | Thinking mode ✅ |
#   | gemini-2.5-pro        | En güçlü   | 1M    | 65K    | Thinking mode ✅ |
#   | gemini-2.0-flash      | Hızlı      | 1M    | 8K     | -               |
#   | gemini-2.5-flash-lite | Hafif      | 1M    | 65K    | Thinking mode ✅ |
# 
#   NOT: "Gemini 3 Flash" diye bir model yok. En yeni seriler Gemini 2.5 ve 2.0.
